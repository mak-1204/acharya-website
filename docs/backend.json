{
  "entities": {
    "HeroBanner": {
      "title": "HeroBanner",
      "description": "Configuration for the homepage hero carousel banners.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ctaText": { "type": "string" },
        "ctaLink": { "type": "string" },
        "isActive": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl", "isActive", "order"]
    },
    "Course": {
      "title": "Course",
      "description": "Detailed course offering information.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "bannerImage": { "type": "string" },
        "price": { "type": "number" },
        "discountedPrice": { "type": "number" },
        "category": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "isPublished", "order"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "Images displayed in the campus gallery section.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "order": { "type": "number" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "order", "isPublished"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Student reviews and success stories.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "photo": { "type": "string" },
        "course": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "review": { "type": "string" },
        "result": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "rating", "review", "isPublished", "order"]
    },
    "Star": {
      "title": "Star",
      "description": "Top performing students and their achievements.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "photo": { "type": "string" },
        "score": { "type": "string" },
        "exam": { "type": "string" },
        "rank": { "type": "string" },
        "courseName": { "type": "string" },
        "quote": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "score", "exam", "isPublished", "order"]
    },
    "Admin": {
      "title": "Admin",
      "description": "List of authorized administrators.",
      "type": "object",
      "properties": {
        "mail id": { "type": "string" },
        "user": { "type": "string" }
      },
      "required": ["mail id"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hero_banners/{bannerId}",
        "definition": {
          "entityName": "HeroBanner",
          "schema": { "$ref": "#/backend/entities/HeroBanner" },
          "description": "Home page banners."
        }
      },
      {
        "path": "/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": { "$ref": "#/backend/entities/Course" },
          "description": "Course catalog."
        }
      },
      {
        "path": "/gallery/{itemId}",
        "definition": {
          "entityName": "GalleryItem",
          "schema": { "$ref": "#/backend/entities/GalleryItem" },
          "description": "Gallery images."
        }
      },
      {
        "path": "/testimonials/{testimonialId}",
        "definition": {
          "entityName": "Testimonial",
          "schema": { "$ref": "#/backend/entities/Testimonial" },
          "description": "Student testimonials."
        }
      },
      {
        "path": "/stars/{starId}",
        "definition": {
          "entityName": "Star",
          "schema": { "$ref": "#/backend/entities/Star" },
          "description": "Top achieving students."
        }
      },
      {
        "path": "/admin/{adminId}",
        "definition": {
          "entityName": "Admin",
          "schema": { "$ref": "#/backend/entities/Admin" },
          "description": "Authorized administrators list."
        }
      }
    ]
  }
}
