rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public collections — read only for public, write for admin
    match /hero_banners/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /courses/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /stars/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /testimonials/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /gallery/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /impact_stats/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /site_settings/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /analytics/{doc} {
      allow read, write: if true;
    }
    match /admin/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}