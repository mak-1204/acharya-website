rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hero banners, categories and courses are publicly readable
    match /hero_banners/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /course_categories/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /sub_courses/{doc} {
      allow read: if true;
      allow write: if false;
    }
    
    // Analytics allows public read and write for tracking
    match /analytics/{doc} {
      allow read, write: if true;
    }

    // Retaining lead capture rules for form functionality
    match /enquiries/{enquiryId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    match /scholarship_leads/{leadId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}